-- ================================================================
--   MODULE 1: COLLECTION_MODULE
--   Xử lý logic tìm / gom / hút đồ
-- ================================================================
local Collection = {}

-- Phân loại một vật phẩm dựa vào tên
function Collection.ClassifyItem(name)
    local lower = name:lower()
    for cat, names in pairs(CONFIG.ItemNames) do
        for _, n in ipairs(names) do
            if lower:find(n:lower()) then
                return cat
            end
        end
    end
    return "Unknown"
end

-- Kiểm tra item có được bật không
function Collection.IsEnabled(category)
    return State.BringEnabled[category] ~= false  -- Unknown luôn enabled nếu không filter
end

-- Tìm tất cả item trên map (BasePart hoặc Model có PrimaryPart)
function Collection.FindAllItems()
    local items = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        -- Tìm các Part/Model không thuộc Player và không phải terrain
        if obj:IsA("BasePart") and not obj:IsDescendantOf(Players.LocalPlayer.Character or Instance.new("Folder")) then
            local cat = Collection.ClassifyItem(obj.Name)
            if cat ~= "Unknown" or true then  -- lấy hết, lọc sau
                table.insert(items, { Part = obj, Category = cat })
            end
        end
    end
    return items
end

-- Gom một item về vị trí camp
function Collection.BringItem(part, targetPos)
    if not part or not part.Parent then return end
    -- Cố gắng tween position (nếu không anchored)
    if not part.Anchored then
        part.CFrame = CFrame.new(targetPos + Vector3.new(math.random(-3,3), 0.5, math.random(-3,3)))
    else
        -- Nếu anchored thì bỏ anchor rồi move
        part.Anchored = false
        task.wait(0.02)
        part.CFrame = CFrame.new(targetPos + Vector3.new(math.random(-3,3), 0.5, math.random(-3,3)))
    end
end

-- Gom tất cả item với delay chống kick
function Collection.BringAll(statusCallback)
    if State.IsBringing then return end
    if not State.CampPosition then
        if statusCallback then statusCallback("⚠ Set Camp trước!") end
        return
    end
    State.IsBringing = true
    task.spawn(function()
        local items = Collection.FindAllItems()
        local count = 0
        local total = #items
        for i, item in ipairs(items) do
            -- Kiểm tra category có được bật không
            if item.Category ~= "Unknown" and not State.BringEnabled[item.Category] then
                -- skip
            else
                Collection.BringItem(item.Part, State.CampPosition)
                count = count + 1
                if statusCallback then
                    statusCallback(string.format("Đang gom... %d/%d", count, total))
                end
                task.wait(CONFIG.BringDelay)  -- delay chống despawn / kick
            end
        end
        if statusCallback then statusCallback(string.format("✓ Gom xong! %d items", count)) end
        State.IsBringing = false
    end)
end

-- Auto-collect loop: hút đồ trong bán kính quanh nhân vật
function Collection.StartAutoCollect()
    task.spawn(function()
        while State.AutoCollect do
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp and State.CampPosition then
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and not obj:IsDescendantOf(char) then
                        local dist = (obj.Position - hrp.Position).Magnitude
                        if dist <= CONFIG.AutoCollectRadius then
                            local cat = Collection.ClassifyItem(obj.Name)
                            if cat == "Unknown" or State.BringEnabled[cat] then
                                Collection.BringItem(obj, State.CampPosition)
                                task.wait(0.05)
                            end
                        end
                    end
                end
            end
            task.wait(0.5)  -- check mỗi 0.5s
        end
    end)
end

