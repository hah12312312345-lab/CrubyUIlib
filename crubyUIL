-- ─── TAB: SETTINGS ───────────────────────────────────────────────
do
    local page = AddPage("Settings")

    AddSectionLabel(page, "THÔNG SỐ")
    local settCard = AddCard(page, 90)

    local function NumRow(parent, label, val, yOff, key)
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -20, 0, 28)
        row.Position = UDim2.new(0, 10, 0, yOff)
        row.BackgroundTransparency = 1
        row.Parent = parent

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.65, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = label
        lbl.TextColor3 = T.Text
        lbl.TextSize = 12
        lbl.Font = Enum.Font.Gotham
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = row

        local box = Instance.new("TextBox")
        box.Size = UDim2.new(0.3, 0, 0.8, 0)
        box.Position = UDim2.new(0.68, 0, 0.1, 0)
        box.BackgroundColor3 = T.BG
        box.Text = tostring(val)
        box.TextColor3 = T.Accent
        box.TextSize = 12
box.Font = Enum.Font.GothamBold
        box.BorderSizePixel = 0
        box.Parent = row

        local bc = Instance.new("UICorner")
        bc.CornerRadius = UDim.new(0, 6)
        bc.Parent = box

        box.FocusLost:Connect(function()
            local n = tonumber(box.Text)
            if n then CONFIG[key] = n end
        end)
    end

    NumRow(settCard, "Bring Delay (s)",    CONFIG.BringDelay,         4,  "BringDelay")
    NumRow(settCard, "Auto-Collect Radius", CONFIG.AutoCollectRadius, 32,  "AutoCollectRadius")
    NumRow(settCard, "Max ESP Distance",   CONFIG.MaxESPDistance,     60,  "MaxESPDistance")

    AddSectionLabel(page, "PHÍM TẮT")
    local keyCard = AddCard(page, 60)
    local keyInfo = Instance.new("TextLabel")
    keyInfo.Size = UDim2.new(1, -20, 1, 0)
    keyInfo.Position = UDim2.new(0, 10, 0, 0)
    keyInfo.BackgroundTransparency = 1
    keyInfo.Text = "[H] Ẩn/hiện cửa sổ\n[B] Bring All nhanh\n[E] Toggle Item ESP"
    keyInfo.TextColor3 = T.SubText
    keyInfo.TextSize = 11
    keyInfo.Font = Enum.Font.Gotham
    keyInfo.TextXAlignment = Enum.TextXAlignment.Left
    keyInfo.TextYAlignment = Enum.TextYAlignment.Center
    keyInfo.Parent = keyCard
end

