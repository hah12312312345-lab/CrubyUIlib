local ESP = {}

-- Tạo BillboardGui trên một part
function ESP.CreateLabel(part, category)
    -- Xóa label cũ nếu có
    ESP.RemoveLabel(part)

    local color = CONFIG.ESPColors[category] or CONFIG.ESPColors.Unknown

    local bb = Instance.new("BillboardGui")
    bb.Name = "_ESP_Label"
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 100, 0, 40)
    bb.StudsOffset = Vector3.new(0, 2, 0)
    bb.Adornee = part
    bb.Parent = part

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.6, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = part.Name
    nameLabel.TextColor3 = color
    nameLabel.TextStrokeTransparency = 0.4
    nameLabel.TextSize = 13
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = bb

    local distLabel = Instance.new("TextLabel")
    distLabel.Size = UDim2.new(1, 0, 0.4, 0)
    distLabel.Position = UDim2.new(0, 0, 0.6, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = "-- m"
    distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLabel.TextStrokeTransparency = 0.5
    distLabel.TextSize = 11
    distLabel.Font = Enum.Font.Gotham
    distLabel.Parent = bb

    State.ESPLabels[part] = { Billboard = bb, DistLabel = distLabel }
end

function ESP.RemoveLabel(part)
    if State.ESPLabels[part] then
        local data = State.ESPLabels[part]
        if data.Billboard and data.Billboard.Parent then
            data.Billboard:Destroy()
        end
        State.ESPLabels[part] = nil
    end
end

function ESP.ClearAll()
    for part, _ in pairs(State.ESPLabels) do
        ESP.RemoveLabel(part)
    end
end

-- Vòng lặp update ESP distance
function ESP.StartUpdateLoop()
    task.spawn(function()
        while State.ItemESP do
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            -- Tìm items mới
            local seen = {}
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and not obj:IsDescendantOf(char or Instance.new("Folder")) then
                    local cat = Collection.ClassifyItem(obj.Name)
                    if cat ~= "Unknown" then
                        seen[obj] = cat
                        if not State.ESPLabels[obj] then
                            ESP.CreateLabel(obj, cat)
                        end
                    end
                end
            end

            -- Update distances + xóa stale labels
            for part, data in pairs(State.ESPLabels) do
                if not part or not part.Parent then
                    ESP.RemoveLabel(part)
                elseif hrp then
                    local dist = math.floor((part.Position - hrp.Position).Magnitude)
                    if dist > CONFIG.MaxESPDistance then
                        data.Billboard.Enabled = false
                    else
                        data.Billboard.Enabled = true
                        data.DistLabel.Text = dist .. " m"
                    end
                end
            end

            task.wait(0.3)
        end
        -- Tắt ESP → xóa hết
        ESP.ClearAll()
    end)
end

