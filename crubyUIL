local tabButtons = {}
local tabPages   = {}

local function SetTab(name)
    State.CurrentTab = name
    for tname, btn in pairs(tabButtons) do
        local active = (tname == name)
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = active and T.Accent or Color3.fromRGB(0,0,0),
            BackgroundTransparency = active and 0.85 or 1,
        }):Play()
        btn.TextColor3 = active and T.Accent or T.SubText
    end
    for tname, page in pairs(tabPages) do
        page.Visible = (tname == name)
    end
end

