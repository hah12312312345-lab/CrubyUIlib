function GroupBox:AddSlider(opts)
	opts = opts or {}
	local min, max = opts.Min or 0, opts.Max or 100
	local default = math.clamp(opts.Default or min, min, max)
	local suffix = opts.Suffix or ""
	local flag = opts.Flag
	local callback = opts.Callback or function() end
	local rounding = opts.Rounding or 0

	local HeaderRow = Util.Create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 16),
		LayoutOrder = NextOrder(self),
	})
	Util.Create("TextLabel", {
		BackgroundTransparency = 1,
		Text = opts.Text or "Slider",
		Font = Theme.FontRegular,
		TextSize = 13,
		TextColor3 = Theme.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.6, 0, 1, 0),
	}).Parent = HeaderRow

	local ValueLabel = Util.Create("TextLabel", {
		BackgroundTransparency = 1,
		Text = tostring(default) .. suffix,
		Font = Theme.FontMedium,
		TextSize = 12,
		TextColor3 = Theme.TextDim,
		TextXAlignment = Enum.TextXAlignment.Right,
		Size = UDim2.new(0.4, 0, 1, 0),
	})
	ValueLabel.Parent = HeaderRow
	HeaderRow.Parent = self.Frame

	local Bar = Util.Create("Frame", {
		BackgroundColor3 = Color3.fromHex("2A2A2A"),
		Size = UDim2.new(1, 0, 0, 6),
		LayoutOrder = HeaderRow.LayoutOrder + 0.5,
	})
	Util.Corner(UDim.new(1, 0)).Parent = Bar

	local Fill = Util.Create("Frame", {
		BackgroundColor3 = Theme.Primary,
		Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
		BorderSizePixel = 0,
	})
	Util.Corner(UDim.new(1, 0)).Parent = Fill
	Fill.Parent = Bar

	local Knob = Util.Create("Frame", {
		BackgroundColor3 = Color3.fromHex("FFFFFF"),
		Size = UDim2.new(0, 14, 0, 14),
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0),
	})
	Util.Corner(UDim.new(1, 0)).Parent = Knob
	Util.Stroke(Theme.Primary, 2, 0).Parent = Knob
	Knob.Parent = Bar

	local DragCatch = Util.Create("TextButton", {
		BackgroundTransparency = 1,
		Text = "",
		Size = UDim2.new(1, 0, 0, 20),
		Position = UDim2.new(0, 0, 0.5, -10),
	})
	DragCatch.Parent = Bar
	Bar.Parent = self.Frame

	local value = default
	local function setFromAlpha(alpha, animated)
		alpha = math.clamp(alpha, 0, 1)
		local raw = min + (max - min) * alpha
		if rounding > 0 then
			raw = math.floor(raw / rounding + 0.5) * rounding
		else
			raw = math.floor(raw + 0.5)
		end
		raw = math.clamp(raw, min, max)
		value = raw
		local a = (value - min) / (max - min)
		local info = animated and EASE.Fast or TweenInfo.new(0)
		Util.Tween(Fill, info, { Size = UDim2.new(a, 0, 1, 0) })
		Util.Tween(Knob, info, { Position = UDim2.new(a, 0, 0.5, 0) })
		ValueLabel.Text = tostring(value) .. suffix
		callback(value)
		if flag then Myth.Flags[flag] = value end
	end

	local dragging = false
	DragCatch.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local rel = (input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X
			setFromAlpha(rel, true)
			local conn
			conn = input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					conn:Disconnect()
				end
			end)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local rel = (input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X
			setFromAlpha(rel, false)
		end
	end)

	if flag then Myth.Flags[flag] = value end

	local api = {}
	function api:Set(v)
		setFromAlpha((v - min) / (max - min), true)
	end
	function api:Get() return value end
	return api
end

