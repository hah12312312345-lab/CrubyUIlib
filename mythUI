			BackgroundTransparency = (opt == selected) and 0.85 or 1,
			AutoButtonColor = false,
			Text = tostring(opt),
			Font = Theme.FontRegular,
			TextSize = 12,
			TextColor3 = (opt == selected) and Theme.Primary or Theme.TextDim,
			TextXAlignment = Enum.TextXAlignment.Left,
			Size = UDim2.new(1, 0, 0, 26),
			LayoutOrder = i,
		})
		Util.Corner(UDim.new(0, 4)).Parent = Row
		Util.Pad(8, 0, 8, 0).Parent = Row
		Util.Hoverable(Row,
			{ BackgroundTransparency = (opt == selected) and 0.85 or 1 },
			{ BackgroundTransparency = 0.85, BackgroundColor3 = Theme.Primary }
		)
		Row.MouseButton1Click:Connect(function()
			selected = opt
			SelectedLabel.Text = tostring(opt)
			for _, sibling in ipairs(scroller:GetChildren()) do
				if sibling:IsA("TextButton") then
					local isSel = sibling.Text == tostring(opt)
					sibling.TextColor3 = isSel and Theme.Primary or Theme.TextDim
					Util.Tween(sibling, EASE.Fast, { BackgroundTransparency = isSel and 0.85 or 1 })
				end
			end
			callback(opt)
			if flag then Myth.Flags[flag] = opt end
