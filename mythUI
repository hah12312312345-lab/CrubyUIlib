		local t = Util.Tween(Main, EASE.Fast, { Size = UDim2.new(Main.Size.X.Scale, Main.Size.X.Offset, 0, 0) })
		t.Completed:Wait()
		Main.Visible = false
	end)

	--// RESPOND TO VIEWPORT CHANGES (responsive scaling) --------------------
	local camera = workspace.CurrentCamera
	if camera then
		camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
			if self.Minimized or maximized then return end
			local newBase = ComputeBaseWindowSize()
			Util.Tween(Main, EASE.Resize, { Size = UDim2.fromOffset(newBase.X, newBase.Y) })
		end)
	end

	Myth.ActiveWindow = self
	table.insert(Myth.Windows, self)

	--// RESIZE HANDLE (floating "}" icon, bottom-right) ----------------------
	self:_AttachResizeHandle()

	return self
end

--[[
	Floating resize handle.

	Idle:    small, dark gray, semi-transparent "}" glyph sitting just
	         outside the window's bottom-right corner.
	Hover:   smoothly enlarges, turns primary red, gains a soft glow.
	Drag:    follows the pointer; window width/height update live,
	         clamped to Min/Max, content re-flows automatically because
	         everything downstream is built with Scale/percentage sizing.
	Release: settles into place with a soft easing tween (no snapping).
]]
function Window:_AttachResizeHandle()
	local Main = self.Main
	local MinSize, MaxSize = self.MinSize, self.MaxSize

	local Handle = Util.Create("TextButton", {
		Name = "ResizeHandle",
		Text = "}",
		Font = Theme.FontBold,
		TextSize = 16,
		TextColor3 = Color3.fromHex("6B6B6B"),
		BackgroundColor3 = Theme.Panel,
		BackgroundTransparency = 0.35,
		AutoButtonColor = false,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(1, 4, 1, 4),
		Size = UDim2.new(0, 22, 0, 22),
		ZIndex = 50,
	})
	Util.Corner(UDim.new(1, 0)).Parent = Handle
	local handleStroke = Util.Stroke(Theme.Stroke, 1, 0.4)
	handleStroke.Parent = Handle

	local glow = Util.Create("ImageLabel", {
		Name = "Glow",
		BackgroundTransparency = 1,
		Image = "rbxassetid://5028857084",
		ImageColor3 = Theme.Primary,
		ImageTransparency = 1,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = SHADOW_SLICE,
		Size = UDim2.new(1, 30, 1, 30),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ZIndex = 49,
	})
	glow.Parent = Handle
	Handle.Parent = Main

	local IDLE = {
		Size = UDim2.new(0, 22, 0, 22),
		BackgroundColor3 = Theme.Panel,
		TextColor3 = Color3.fromHex("6B6B6B"),
	}
	local HOVER = {
		Size = UDim2.new(0, 28, 0, 28),
		BackgroundColor3 = Theme.Primary,
		TextColor3 = Theme.Text,
	}

	local hovering, dragging = false, false

	local function applyIdle()
		Util.Tween(Handle, EASE.Smooth, IDLE)
		Util.Tween(glow, EASE.Smooth, { ImageTransparency = 1 })
		Util.Tween(handleStroke, EASE.Smooth, { Transparency = 0.4 })
	end

	local function applyHover()
		Util.Tween(Handle, EASE.Pop, HOVER)
		Util.Tween(glow, EASE.Smooth, { ImageTransparency = 0.55 })
		Util.Tween(handleStroke, EASE.Smooth, { Transparency = 0, Color = Theme.Primary })
	end

	Handle.MouseEnter:Connect(function()
		hovering = true
		applyHover()
	end)
	Handle.MouseLeave:Connect(function()
		hovering = false
		if not dragging then applyIdle() end
	end)

	local dragStartPos, startSize
	Handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStartPos = input.Position
			startSize = Main.Size
			applyHover()

			local conn
			conn = input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					conn:Disconnect()
					-- Soft settle animation on release (re-affirms current size with easing)
					Util.Tween(Main, EASE.Resize, { Size = Main.Size })
					if not hovering then applyIdle() end
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStartPos

			local newW = math.clamp(startSize.X.Offset + delta.X, MinSize.X, MaxSize.X)
			local newH = math.clamp(startSize.Y.Offset + delta.Y, MinSize.Y, MaxSize.Y)

			-- Direct, real-time assignment (no tween while actively dragging,
			-- so the frame tracks the pointer with zero lag); layout below
			-- re-flows automatically since children use Scale-based sizing.
			Main.Size = UDim2.new(0, newW, 0, newH)
		end
	end)

	-- Keep handle glued to the bottom-right corner regardless of resizing.
	Main:GetPropertyChangedSignal("Size"):Connect(function()
		-- Position is anchored via UDim2.new(1,4,1,4) with AnchorPoint(0.5,0.5)
		-- relative to Main, so no manual repositioning is required; this hook
		-- is reserved for any future layout-dependent behavior.
	end)

	self.ResizeHandle = Handle
end

