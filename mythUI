--// RIPPLE CLICK EFFECT ---------------------------------------------------
function Util.Ripple(button, color)
	button.ClipsDescendants = true
	button.MouseButton1Down:Connect(function()
		local pos = UserInputService:GetMouseLocation()
		local abs = button.AbsolutePosition
		local size = button.AbsoluteSize

		local ripple = Util.Create("Frame", {
			BackgroundColor3 = color or Theme.Primary,
			BackgroundTransparency = 0.65,
			BorderSizePixel = 0,
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0, pos.X - abs.X, 0, pos.Y - abs.Y - 36),
			Size = UDim2.new(0, 0, 0, 0),
			ZIndex = button.ZIndex + 1,
		})
		Util.Corner(UDim.new(1, 0)).Parent = ripple
		ripple.Parent = button

		local maxDim = math.max(size.X, size.Y) * 2.2
		Util.Tween(ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, maxDim, 0, maxDim),
			BackgroundTransparency = 1,
		})
		task.delay(0.5, function()
			ripple:Destroy()
		end)
	end)
end

--// HOVER STATE HELPER -----------------------------------------------------
function Util.Hoverable(instance, normalProps, hoverProps, info)
	info = info or EASE.Fast
	instance.MouseEnter:Connect(function()
		Util.Tween(instance, info, hoverProps)
	end)
	instance.MouseLeave:Connect(function()
		Util.Tween(instance, info, normalProps)
	end)
end

--// DRAGGABLE (generic, used by window header) ----------------------------
function Util.MakeDraggable(handle, target)
	local dragging = false
	local dragStart, startPos

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = target.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			target.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

--// RESPONSIVE HELPERS ------------------------------------------------------
-- The window is sized proportionally to viewport, clamped between a min and
-- max, so it behaves on phone / tablet / PC without ever stretching oddly.
local function GetViewportSize()
	local camera = workspace.CurrentCamera
	return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

local function ComputeBaseWindowSize()
	local vp = GetViewportSize()
	-- Vertical layout: height significantly larger than width.
	local w = math.clamp(vp.X * 0.30, 300, 460)
	local h = math.clamp(vp.Y * 0.82, 460, 760)
	-- On very small (phone) viewports, use a larger share of the screen.
	if vp.X < 500 then
		w = math.clamp(vp.X * 0.92, 260, 420)
		h = math.clamp(vp.Y * 0.86, 420, 700)
	end
	return Vector2.new(w, h)
end

