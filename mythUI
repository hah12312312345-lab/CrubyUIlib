		end
	end

	Head.MouseButton1Click:Connect(toggleExpand)
	Wrap.Parent = self.Frame

	if flag then Myth.Flags[flag] = selected end

	local api = {}
	function api:Set(opt)
		selected = opt
		SelectedLabel.Text = tostring(opt)
		if flag then Myth.Flags[flag] = opt end
	end
	function api:Get() return selected end
	function api:Refresh(newOptions)
		options = newOptions
		for _, c in ipairs(Scroller:GetChildren()) do
			if c:IsA("TextButton") then c:Destroy() end
		end
		for i, opt in ipairs(options) do
			createRow(Scroller, opt, i)
		end
		if selected and not table.find(options, selected) then
			selected = options[1]
			SelectedLabel.Text = tostring(selected or "Select...")
		end
	end
	return api
end

