	UserInputService.InputChanged:Connect(function(input)
		if pickingHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setFromBarX(input.Position.X - GradientBar.AbsolutePosition.X)
		end
	end)

	local expanded = false
	Head.MouseButton1Click:Connect(function()
		expanded = not expanded
		Util.Tween(Panel, EASE.Smooth, { Size = UDim2.new(1, 0, 0, expanded and 66 or 0) })
	end)

	if flag then Myth.Flags[flag] = color end

	local api = {}
	function api:Set(c)
		color = c
		updateSwatch()
	end
	function api:Get() return color end
	return api
end

--// ============================================================================
--// THEME MANAGER
--// ============================================================================
-- Lets end-users retint the whole interface (primary color, brightness,
-- corner style, border thickness) live, with every open component updating
-- through the same Theme table this file already reads from.
local PRESET_THEMES = {
	["Myth Red"]   = { Primary = "E53935" },
	["Cyber Cyan"] = { Primary = "3DDCDC" },
	["Amber"]      = { Primary = "FFA83D" },
	["Emerald"]    = { Primary = "3DDC84" },
	["Sapphire"]   = { Primary = "3D8BFF" },
	["Violet"]     = { Primary = "8B3DFF" },
	["Magenta"]    = { Primary = "FF3DC9" },
	["Mono"]       = { Primary = "CCCCCC" },
}

local ThemeSubscribers = {}
local function BroadcastThemeChange()
	for _, fn in ipairs(ThemeSubscribers) do
		pcall(fn, Theme)
	end
end

function GroupBox:AddThemeManagerPreview()
	-- Theme select dropdown
	local themeNames = {}
	for name in pairs(PRESET_THEMES) do table.insert(themeNames, name) end
	table.sort(themeNames)

	self:AddLabel("Select theme")
	local ThemeDropdown = self:AddDropdown({
		Options = themeNames,
		Default = "Myth Red",
		Callback = function(name)
			local preset = PRESET_THEMES[name]
			if preset and preset.Primary then
				Theme.Primary = Color3.fromHex(preset.Primary)
				BroadcastThemeChange()
			end
		end,
	})

	self:AddLabel("Preset accents")
	local SwatchRow = Util.Create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 24),
		LayoutOrder = NextOrder(self),
	})
	Util.Create("UIListLayout", {
		FillDirection = Enum.FillDirection.Horizontal,
		Padding = UDim.new(0, 6),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = SwatchRow
	for name, preset in pairs(PRESET_THEMES) do
		local sw = Util.Create("TextButton", {
			BackgroundColor3 = Color3.fromHex(preset.Primary),
			AutoButtonColor = false,
			Text = "",
			Size = UDim2.new(0, 22, 0, 22),
		})
		Util.Corner(UDim.new(0, 6)).Parent = sw
		Util.Stroke(Color3.fromHex("000000"), 1, 0.5).Parent = sw
		sw.MouseButton1Click:Connect(function()
			Theme.Primary = Color3.fromHex(preset.Primary)
			BroadcastThemeChange()
		end)
		sw.Parent = SwatchRow
	end
	SwatchRow.Parent = self.Frame

	self:AddSlider({
		Text = "Panel brightness",
		Min = 0, Max = 100, Default = 9, Suffix = "%",
		Callback = function(v)
			local level = 0.09 + (v / 100) * 0.15
			Theme.Panel = Color3.fromHSV(0, 0, level)
			BroadcastThemeChange()
		end,
	})

	self:AddDropdown({
		Text = "Corner style",
		Options = { "Sharp", "Default", "Rounded" },
		Default = "Default",
		Callback = function(v)
			local radius = ({ Sharp = 2, Default = 8, Rounded = 14 })[v]
			Theme.CornerRadius = UDim.new(0, radius)
			BroadcastThemeChange()
		end,
	})

	return { Subscribe = function(fn) table.insert(ThemeSubscribers, fn) end }
end

--// ============================================================================
--// CONFIG MANAGER
--// ============================================================================
-- Save / load Myth.Flags snapshots by name. Persistence layer (file write)
-- is left as a hook (SaveToFile / LoadFromFile) so it can be wired to
-- writefile/readfile in a real executor environment without touching UI code.
local ConfigStore = {}   -- name -> serialized flag table (in-memory registry)

local function SerializeFlags()
	local snapshot = {}
	for k, v in pairs(Myth.Flags) do
		if typeof(v) == "Color3" then
			snapshot[k] = { __type = "Color3", value = v:ToHex() }
		elseif typeof(v) == "EnumItem" then
			snapshot[k] = { __type = "Enum", value = v.Name }
		else
			snapshot[k] = v
		end
	end
	return snapshot
end

local function ApplyFlags(snapshot)
	for k, v in pairs(snapshot) do
		if type(v) == "table" and v.__type == "Color3" then
			Myth.Flags[k] = Color3.fromHex(v.value)
		elseif type(v) == "table" and v.__type == "Enum" then
			Myth.Flags[k] = Enum.KeyCode[v.value]
		else
			Myth.Flags[k] = v
		end
	end
end

function Myth:SaveConfig(name)
	ConfigStore[name] = SerializeFlags()
	self:Notify({ Title = "Config saved", Content = '"' .. name .. '" stored successfully.', Type = "Success" })
end

function Myth:LoadConfig(name)
	local snap = ConfigStore[name]
	if not snap then
		self:Notify({ Title = "Load failed", Content = '"' .. name .. '" was not found.', Type = "Error" })
		return
	end
	ApplyFlags(snap)
	self:Notify({ Title = "Config loaded", Content = '"' .. name .. '" applied.', Type = "Success" })
end

function Myth:DeleteConfig(name)
	ConfigStore[name] = nil
	self:Notify({ Title = "Config deleted", Content = '"' .. name .. '" removed.', Type = "Warning" })
end

function Myth:ListConfigs()
	local list = {}
	for name in pairs(ConfigStore) do table.insert(list, name) end
	table.sort(list)
	return list
end

-- Convenience UI builder: drops a full Config Manager groupbox (list +
-- Load / Save / Delete / Create actions) into any Section.
function Section:AddConfigManager()
	local ListBox = self:AddGroupBox("Saved configs")
	local ActionsBox = self:AddGroupBox("Actions")

	local currentSelection = nil
	local rows = {}

	local ListHolder = Util.Create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		LayoutOrder = NextOrder(ListBox),
	})
	Util.Create("UIListLayout", {
		Padding = UDim.new(0, 6),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = ListHolder
	ListHolder.Parent = ListBox.Frame

	local function refreshList()
		for _, r in ipairs(rows) do r:Destroy() end
		table.clear(rows)
		for i, name in ipairs(Myth:ListConfigs()) do
			local Row = Util.Create("TextButton", {
				BackgroundColor3 = (name == currentSelection) and Theme.Primary or Theme.PanelLight,
				BackgroundTransparency = (name == currentSelection) and 0.85 or 1,
				AutoButtonColor = false,
				Text = name,
				Font = Theme.FontRegular,
				TextSize = 12,
				TextColor3 = (name == currentSelection) and Theme.Primary or Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				Size = UDim2.new(1, 0, 0, 28),
				LayoutOrder = i,
			})
			Util.Corner(UDim.new(0, 5)).Parent = Row
			Util.Pad(10, 0, 10, 0).Parent = Row
			Row.MouseButton1Click:Connect(function()
				currentSelection = name
				refreshList()
			end)
			Row.Parent = ListHolder
			table.insert(rows, Row)
		end
	end
	refreshList()

	ActionsBox:AddButton({
		Text = "Load config",
		Variant = "Primary",
		Callback = function()
			if currentSelection then Myth:LoadConfig(currentSelection) end
		end,
	})
	ActionsBox:AddButton({
		Text = "Save config",
		Variant = "Secondary",
		Callback = function()
			if currentSelection then
				Myth:SaveConfig(currentSelection)
				refreshList()
			end
		end,
	})
	ActionsBox:AddButton({
		Text = "Delete config",
		Variant = "Secondary",
		Callback = function()
			if currentSelection then
				Myth:DeleteConfig(currentSelection)
				currentSelection = nil
				refreshList()
			end
		end,
	})
	ActionsBox:AddTextbox({
		Placeholder = "New config name...",
		Callback = function(text, enterPressed)
			if enterPressed and text ~= "" then
				Myth:SaveConfig(text)
				currentSelection = text
				refreshList()
			end
		end,
	})

	return { Refresh = refreshList }
end

return Myth
