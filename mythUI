		LayoutOrder = -os.clock() * 1000,
	})
	Util.Corner(Theme.CornerRadiusSm).Parent = card
	Util.Stroke(meta.Color, 1, 0.35).Parent = card
	Util.Shadow(card, 0.6, 24)

	local accent = Util.Create("Frame", {
		BackgroundColor3 = meta.Color,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 3, 1, 0),
	})
	Util.Corner(UDim.new(0, 2)).Parent = accent
	accent.Parent = card

	local icon = Util.Create("ImageLabel", {
		BackgroundTransparency = 1,
		Image = meta.Icon,
		ImageColor3 = meta.Color,
		Size = UDim2.new(0, 20, 0, 20),
		Position = UDim2.new(0, 16, 0, 12),
	})
	icon.Parent = card

	local title = Util.Create("TextLabel", {
		BackgroundTransparency = 1,
		Text = opts.Title or "Notification",
		Font = Theme.FontBold,
		TextSize = 14,
		TextColor3 = meta.Color,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.new(0, 46, 0, 8),
		Size = UDim2.new(1, -80, 0, 18),
	})
	title.Parent = card

	local desc = Util.Create("TextLabel", {
		BackgroundTransparency = 1,
		Text = opts.Content or "",
		Font = Theme.FontRegular,
		TextSize = 12,
		TextColor3 = Theme.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		Position = UDim2.new(0, 46, 0, 27),
		Size = UDim2.new(1, -80, 0, 28),
	})
	desc.Parent = card

	local closeBtn = Util.Create("TextButton", {
		BackgroundTransparency = 1,
		Text = "\226\156\149",
		Font = Theme.FontMedium,
		TextSize = 14,
		TextColor3 = Theme.TextFaint,
		Size = UDim2.new(0, 24, 0, 24),
		Position = UDim2.new(1, -30, 0, 8),
	})
	closeBtn.Parent = card

	card.Parent = holder

	-- Slide + fade in
	card.Position = UDim2.new(1, 60, 0, 0)
	card.BackgroundTransparency = 1
	icon.ImageTransparency = 1
	title.TextTransparency = 1
	desc.TextTransparency = 1
	Util.Tween(card, EASE.Slide, { Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0 })
	Util.Tween(icon, EASE.Slide, { ImageTransparency = 0 })
	Util.Tween(title, EASE.Slide, { TextTransparency = 0 })
	Util.Tween(desc, EASE.Slide, { TextTransparency = 0 })

	local function dismiss()
		local slide = Util.Tween(card, EASE.Smooth, { Position = UDim2.new(1, 60, 0, 0), BackgroundTransparency = 1 })
		Util.Tween(icon, EASE.Smooth, { ImageTransparency = 1 })
		Util.Tween(title, EASE.Smooth, { TextTransparency = 1 })
		Util.Tween(desc, EASE.Smooth, { TextTransparency = 1 })
		slide.Completed:Wait()
		card:Destroy()
	end

	closeBtn.MouseButton1Click:Connect(dismiss)
	task.delay(opts.Duration or 4.5, function()
		if card.Parent then
			pcall(dismiss)
		end
	end)
end

