--// Animated tab switching --------------------------------------------------
function Window:SelectTab(tabObj)
	if self.ActiveTab == tabObj then return end
	local previous = self.ActiveTab
	self.ActiveTab = tabObj

	if previous then
		Util.Tween(previous.Button, EASE.Fast, { BackgroundTransparency = 1 })
		Util.Tween(previous.Label, EASE.Fast, { TextColor3 = Theme.TextFaint })
		if previous.Icon then Util.Tween(previous.Icon, EASE.Fast, { ImageColor3 = Theme.TextFaint }) end
		Util.Tween(previous.Indicator, EASE.Fast, { Size = UDim2.new(0, 0, 0, 2) })

		-- swap visibility immediately; the incoming page handles the
		-- animated transition (slide + fade) so the switch still feels smooth
		previous.Page.Visible = false
	end

	Util.Tween(tabObj.Button, EASE.Fast, { BackgroundTransparency = 0 })
	Util.Tween(tabObj.Label, EASE.Fast, { TextColor3 = Theme.Primary })
	if tabObj.Icon then Util.Tween(tabObj.Icon, EASE.Fast, { ImageColor3 = Theme.Primary }) end
	Util.Tween(tabObj.Indicator, EASE.Pop, { Size = UDim2.new(0.7, 0, 0, 2) })

	-- Slide-in transition for the newly active page
	local page = tabObj.Page
	page.Visible = true
	page.Position = UDim2.new(0.03, 0, 0, 0)
	Util.Tween(page, EASE.Slide, { Position = UDim2.new(0, 0, 0, 0) })
end

